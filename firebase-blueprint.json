{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "name": { "type": "string", "description": "User's full name." },
        "role": { "type": "string", "enum": ["admin", "printer", "client"], "description": "User's role in the system." },
        "photoUrl": { "type": "string", "format": "uri", "description": "URL to the user's profile picture." }
      },
      "required": ["uid", "email", "name", "role"]
    },
    "projects": {
      "title": "Project",
      "description": "Represents a printing project.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the project." },
        "name": { "type": "string", "description": "Name of the project." },
        "description": { "type": "string", "description": "Detailed description of the project." },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed", "cancelled"], "description": "Current status of the project." },
        "clientId": { "type": "string", "description": "UID of the client who owns the project." },
        "printerId": { "type": "string", "description": "UID of the printer assigned to the project." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the project was created." },
        "deadline": { "type": "string", "format": "date-time", "description": "Project deadline." }
      },
      "required": ["name", "status", "clientId", "createdAt"]
    },
    "idCards": {
      "title": "ID Card",
      "description": "Represents an individual ID card within a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the ID card." },
        "projectId": { "type": "string", "description": "ID of the project this card belongs to." },
        "name": { "type": "string", "description": "Name on the ID card." },
        "photoUrl": { "type": "string", "format": "uri", "description": "URL to the photo for the ID card." },
        "status": { "type": "string", "enum": ["pending", "printed", "shipped"], "description": "Current status of the ID card." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the ID card record was created." }
      },
      "required": ["projectId", "name", "status", "createdAt"]
    },
    "notifications": {
      "title": "Notification",
      "description": "System notifications for users.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the notification." },
        "userId": { "type": "string", "description": "UID of the user to receive the notification." },
        "message": { "type": "string", "description": "Notification message." },
        "read": { "type": "boolean", "description": "Whether the notification has been read." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the notification was created." }
      },
      "required": ["userId", "message", "read", "createdAt"]
    },
    "documents": {
      "title": "Document",
      "description": "Stores metadata for uploaded project files.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the document." },
        "name": { "type": "string", "description": "Original file name." },
        "url": { "type": "string", "format": "uri", "description": "Download URL from Firebase Storage." },
        "type": { "type": "string", "description": "MIME type of the file." },
        "size": { "type": "number", "description": "File size in bytes." },
        "uploadedAt": { "type": "string", "format": "date-time", "description": "Timestamp when the file was uploaded." },
        "userId": { "type": "string", "description": "UID of the user who uploaded the file." },
        "storagePath": { "type": "string", "description": "Full path in Firebase Storage." }
      },
      "required": ["name", "url", "type", "size", "uploadedAt", "userId"]
    },
    "notes": {
      "title": "Note",
      "description": "Quick notes and ideas for users.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the note." },
        "title": { "type": "string", "description": "Optional title for the note." },
        "content": { "type": "string", "description": "The text content of the note." },
        "color": { "type": "string", "description": "Background color class for the note." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the note was created." },
        "userId": { "type": "string", "description": "UID of the user who owns the note." }
      },
      "required": ["content", "createdAt", "userId"]
    },
    "tasks": {
      "title": "Task",
      "description": "Daily tasks and to-do items.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the task." },
        "title": { "type": "string", "description": "Task description." },
        "date": { "type": "string", "description": "Target date for the task (YYYY-MM-DD)." },
        "completed": { "type": "boolean", "description": "Whether the task is finished." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the task was created." },
        "userId": { "type": "string", "description": "UID of the user who owns the task." }
      },
      "required": ["title", "date", "completed", "createdAt", "userId"]
    },
    "clients": {
      "title": "Client",
      "description": "Represents a client or organization.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the client." },
        "name": { "type": "string", "description": "Full name of the client or company." },
        "email": { "type": "string", "format": "email", "description": "Email address." },
        "phone": { "type": "string", "description": "Phone number." },
        "type": { "type": "string", "description": "Type of client (e.g., School, Company)." },
        "contact": { "type": "string", "description": "Primary contact person." },
        "status": { "type": "string", "enum": ["Active", "Inactive"], "description": "Current status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the client was created." }
      },
      "required": ["name", "email", "status", "createdAt"]
    },
    "staff": {
      "title": "Staff Member",
      "description": "Represents a staff member or employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the staff member." },
        "name": { "type": "string", "description": "Full name of the staff member." },
        "email": { "type": "string", "format": "email", "description": "Email address." },
        "phone": { "type": "string", "description": "Contact number." },
        "role": { "type": "string", "enum": ["Staff", "Salesperson", "Credit_manager", "Accounts", "Admin"], "description": "Role of the staff member." },
        "address": { "type": "string", "description": "Full address." },
        "pincode": { "type": "string", "description": "Pincode." },
        "city": { "type": "string", "description": "City." },
        "state": { "type": "string", "description": "State." },
        "district": { "type": "string", "description": "District." },
        "status": { "type": "string", "enum": ["Active", "Inactive"], "description": "Current status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the staff member was created." },
        "createdBy": { "type": "string", "description": "UID of the user who added the staff member." }
      },
      "required": ["name", "email", "role", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents."
    },
    "/projects/{projectId}": {
      "schema": "projects",
      "description": "Project documents."
    },
    "/clients/{clientId}": {
      "schema": "clients",
      "description": "Client documents."
    },
    "/projects/{projectId}/idCards/{idCardId}": {
      "schema": "idCards",
      "description": "ID card documents within a project."
    },
    "/notifications/{notificationId}": {
      "schema": "notifications",
      "description": "User notifications."
    },
    "/documents/{docId}": {
      "schema": "documents",
      "description": "User documents."
    },
    "/notes/{noteId}": {
      "schema": "notes",
      "description": "User notes."
    },
    "/tasks/{taskId}": {
      "schema": "tasks",
      "description": "User tasks."
    },
    "/staff/{staffId}": {
      "schema": "staff",
      "description": "Staff member documents."
    }
  }
}
